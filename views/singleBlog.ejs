<!DOCTYPE html>
<html lang="en">
<%- include('partials/head.ejs') %>

    <body>
        <%- include('partials/nav.ejs') %>
           <div class="container d-flex justify-content-center align-items-center flex-column mb-5">
            <img src="<%= blog.coverImage %>" class="blogImg"/>
            <h3><%= blog.title %></h3>
            <h5>Created By : <%= blog.createdBy.name %></h5>
            <p><%= blog.body %></p>
            <% if (locals.user) { %>
             <form action="/comment/<%= blog._id %>" method="POST">
                <input class="form-control" type="text" name="content" placeholder="Enter Your Comment"/> <br/>
                <button type="submit" class="btn btn-primary">Post</button>
            </form>
            <br/>
            <% } %>
            <h3>Comments (<%=comments.length %>):</h3>
            <% comments.forEach(comment => { %>
               <div class="d-flex mt-4 align-items-center justify-content-between border px-3 py-2 w-25">
                 <img src="<%= comment.createdBy?.image %>" class="me-3 commentImg"/>
                 <h3 class="mb-0"><%= comment.content %></h3>
               </div>
            <% }) %>

            </div>
        <%- include('partials/script.ejs') %>
    </body>

</html>